{
  "name": "easystore",
  "version": "1.0.0",
  "private": true,
  "main": "desktop/electron/main.js",
  "description": "EasyStore com frontend estatico e backend Node para Supabase.",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "start": "node server.js",
    "start:modular": "node modular-server.js",
    "desktop": "electron ./desktop/electron/main.js",
    "build:desktop": "electron-builder --win nsis --x64 --publish never"
  },
  "dependencies": {
    "axios": "^1.13.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "fast-xml-parser": "^5.3.0",
    "node-forge": "^1.3.1",
    "node-sped-nfe": "^1.2.52",
    "pdfkit": "^0.17.2",
    "qrcode": "^1.5.4",
    "xml-crypto": "^6.1.2"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.easystore.desktop",
    "productName": "EasyStore",
    "directories": {
      "output": "dist/desktop"
    },
    "files": [
      "desktop/electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
